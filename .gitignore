# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editors
*.un~
.idea/
.vscode/

# Lighthouse CI artifacts
lhci-results/
.lighthouseci/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# next-pwa generated artifacts (regenerated on every `bun run build`)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# Convex generated bindings — committed per canonical Convex guidance
# (skills/convex-quickstart explicitly says "check this into git").
# Earlier this was gitignored on a wrong reading of Convex docs; that
# choice broke Vercel deploys (the build can't resolve the api import
# without the generated files in the repo). Now committed.
#
# The ai-files subdirectory is local IDE/agent guidance only — Convex's
# `npx convex ai-files install` writes it for tools to read locally.
# Doesn't belong in the deployed build; gitignore just that subdir.
/convex/_generated/ai/
